              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status in expected range', function () {",
                  "  pm.expect([201,400,401,403,404,500]).to.include(pm.response.code);",
                  "});",
                  "pm.test('JSON has data or error', function () {",
                  "  try { const j = pm.response.json(); pm.expect(j.data !== undefined || j.error !== undefined).to.be.true; } catch (e) { pm.expect.fail('Invalid JSON'); }",
                  "});",
                  "try {",
                  "  const j = pm.response.json();",
                  "  if (j.data && j.data.user_id) {",
                  "    pm.environment.set('user_id', j.data.user_id);",
