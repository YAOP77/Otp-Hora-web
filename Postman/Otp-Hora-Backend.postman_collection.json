            "body": {
              "mode": "raw",
              "raw": "{\n  \"nom_entreprise\": \"Nouveau nom\",\n  \"phone\": \"+2250700000001\",\n  \"pin\": \"123456\"\n}"
            },
            "url": "{{base_url}}/enterprises/me",
