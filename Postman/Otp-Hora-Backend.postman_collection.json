              "raw": "{\n  \"email\": \"contact@entreprise.com\"\n}"
            },
            "url": "{{base_url}}/enterprises/me/recovery-email",
            "description": "Email de récupération entreprise ; `email_verified` repasse à false jusqu'à POST /enterprises/email/verify."
          }
        },
        {
          "name": "[PUBLIC] POST Verify enterprise email",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"<jwt depuis logs serveur>\"\n}"
            },
            "url": "{{base_url}}/enterprises/email/verify",
            "description": "Confirme l'email entreprise (type `enterprise_email_verify`)."
          }
        },
        {
          "name": "[PUBLIC] POST Enterprise PIN recovery request",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contact\": \"+2250700000000\"\n}"
            },
            "url": "{{base_url}}/enterprises/pin-recovery/request",
            "description": "Corps : `contact` ou `phone` ou `phone_number` (E.164). Email **vérifié** requis. Sinon `RECOVERY_EMAIL_REQUIRED`."
          }
        },
        {
          "name": "[PUBLIC] POST Enterprise PIN recovery confirm",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"<token email ou logs>\",\n  \"pin\": \"654321\"\n}"
            },
            "url": "{{base_url}}/enterprises/pin-recovery/confirm",
            "description": "`token` + `pin` (ou `code_pin` / `PIN` ; chaîne ou nombre). Réinitialise le PIN ; invalide les JWT (token_version)."
          }
        },
