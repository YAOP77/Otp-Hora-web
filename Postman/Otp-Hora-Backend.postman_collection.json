            "method": "DELETE",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{company_access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pin\": \"123456\"\n}"
            },
            "url": "{{base_url}}/enterprises/me",
            "description": "Suppression logique : `deleted_at`, statut `deleted`, liens `revoked`, tokens invalidés."
          }
        },
        {
          "name": "[ENTREPRISE] PUT Recovery email (authentifié)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{company_access_token}}" }
